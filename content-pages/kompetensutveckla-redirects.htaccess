# =============================================================================
# SECTION 6: WEBBUTBILDNINGAR (online courses)
# =============================================================================

# --- Specific sub-categories first ---
Redirect 301 /webbutbildningar/webbutbildningar-arbetsmiljo/ /utbildningar/arbetsmiljo/
Redirect 301 /webbutbildningar/webbutbildningar-elsakerhet/ /utbildningar/elsakerhet/
Redirect 301 /webbutbildningar/webbutbildningar-sakerhet/ /utbildningar/sakerhet/
Redirect 301 /webbutbildningar/webbutbildningar-vag-och-transport/ /utbildningar/vag-och-transport/
Redirect 301 /webbutbildningar/webbutbildningar-ledarskap/ /utbildningar/ledarskap/

# --- Webbutbildningar category root ---
Redirect 301 /webbutbildningar/ /utbildningar/

# --- Catch-all for any individual web course pages under sub-categories ---
RewriteRule ^webbutbildningar/webbutbildningar-arbetsmiljo/.+$ /utbildningar/arbetsmiljo/ [R=301,L]
RewriteRule ^webbutbildningar/webbutbildningar-elsakerhet/.+$ /utbildningar/elsakerhet/ [R=301,L]
RewriteRule ^webbutbildningar/webbutbildningar-sakerhet/.+$ /utbildningar/sakerhet/ [R=301,L]
RewriteRule ^webbutbildningar/webbutbildningar-vag-och-transport/.+$ /utbildningar/vag-och-transport/ [R=301,L]
RewriteRule ^webbutbildningar/webbutbildningar-ledarskap/.+$ /utbildningar/ledarskap/ [R=301,L]

# --- Any other webbutbildningar sub-page → /utbildningar/ ---
RewriteRule ^webbutbildningar/.+$ /utbildningar/ [R=301,L]


# =============================================================================
# SECTION 7: FYSISKA UTBILDNINGAR (in-person courses)
# =============================================================================

# --- Specific sub-categories first ---
Redirect 301 /fysiska-utbildningar/fysiska-arbetsmiljoutbildningar/ /utbildningar/arbetsmiljo/
Redirect 301 /fysiska-utbildningar/fysiska-ledarskapsutbildningar/ /utbildningar/ledarskap/
Redirect 301 /fysiska-utbildningar/utbildningar-for-tekniska-anordningar/ /utbildningar/sakerhet/

# --- Fysiska utbildningar category root ---
Redirect 301 /fysiska-utbildningar/ /utbildningar/

# --- Catch-all for individual in-person courses ---
RewriteRule ^fysiska-utbildningar/fysiska-arbetsmiljoutbildningar/.+$ /utbildningar/arbetsmiljo/ [R=301,L]
RewriteRule ^fysiska-utbildningar/fysiska-ledarskapsutbildningar/.+$ /utbildningar/ledarskap/ [R=301,L]
RewriteRule ^fysiska-utbildningar/utbildningar-for-tekniska-anordningar/.+$ /utbildningar/sakerhet/ [R=301,L]
RewriteRule ^fysiska-utbildningar/.+$ /utbildningar/ [R=301,L]


