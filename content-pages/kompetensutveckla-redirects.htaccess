# --- Catch-all for individual teacher-led courses ---
RewriteRule ^lararledda-webbutbildningar/.+$ /utbildningar/ [R=301,L]


# =============================================================================
# SECTION 11: VARA TJANSTER / KUNSKAPSBANK
# =============================================================================

# --- Specific tool/assessment pages → checklistor ---
Redirect 301 /vara-tjanster/arbetsmiljoarbete/keds/ /kunskapsbank/checklistor/
Redirect 301 /vara-tjanster/arbetsmiljoarbete/pss-10/ /kunskapsbank/checklistor/

# --- Cost-related articles → artiklar ---
Redirect 301 /vara-tjanster/arbetsmiljoarbete/kostnaden-for-stress/ /kunskapsbank/artiklar/
Redirect 301 /vara-tjanster/arbetsmiljoarbete/kostnaden-for-krankande/ /kunskapsbank/artiklar/

# --- KEDS English → English courses ---
Redirect 301 /vara-tjanster/arbetsmiljoarbete/keds-english/ /utbildningar/english-courses/

# --- SAM/systematiskt arbetsmiljoarbete → rutiner ---
Redirect 301 /vara-tjanster/arbetsmiljoarbete/om-systematiskt-arbetsmiljoarbete/ /kunskapsbank/rutiner/

# --- Kunskapstest → bygg ---
Redirect 301 /vara-tjanster/arbetsmiljoarbete/kunskapstest-bas/ /utbildningar/bygg/

# --- Kunskapsbanken root → artiklar ---
Redirect 301 /vara-tjanster/arbetsmiljoarbete/kunskapsbanken/ /kunskapsbank/artiklar/

# --- Rutiner ---
Redirect 301 /vara-tjanster/arbetsmiljoarbete/rutiner/ /kunskapsbank/rutiner/

# --- Lagar och foreskrifter ---
Redirect 301 /vara-tjanster/arbetsmiljoarbete/arbetsmiljolag/ /kunskapsbank/lagar/
Redirect 301 /vara-tjanster/arbetsmiljoarbete/arbetstidslagen/ /kunskapsbank/lagar/
Redirect 301 /vara-tjanster/arbetsmiljoarbete/afs/ /kunskapsbank/lagar/
Redirect 301 /vara-tjanster/arbetsmiljoarbete/arbetsmiljoforordningen/ /kunskapsbank/lagar/
Redirect 301 /vara-tjanster/arbetsmiljoarbete/afs/afs-2023/ /kunskapsbank/lagar/
Redirect 301 /vara-tjanster/arbetsmiljoarbete/afs/foreskrifter-ovriga/ /kunskapsbank/lagar/
Redirect 301 /vara-tjanster/arbetsmiljoarbete/afs/produktregler-arbetsmiljoverket/ /kunskapsbank/lagar/

# --- Catch-all for AFS sub-pages → lagar ---
RewriteRule ^vara-tjanster/arbetsmiljoarbete/afs/.+$ /kunskapsbank/lagar/ [R=301,L]

# --- Catch-all for rutiner sub-pages ---
RewriteRule ^vara-tjanster/arbetsmiljoarbete/rutiner/.+$ /kunskapsbank/rutiner/ [R=301,L]

# --- Utbildningstjanster → utbildningar ---
Redirect 301 /vara-tjanster/vara-arbetsmiljoutbildningar/ /utbildningar/
Redirect 301 /vara-tjanster/vara-arbetsmiljoutbildningar/foretagsanpassade-arbetsmiljoutbildningar/ /utbildningar/
Redirect 301 /vara-tjanster/vara-arbetsmiljoutbildningar/foretagsforlagda-arbetsmiljoutbildningar/ /utbildningar/

# --- Ledningssystem → kunskapsbank ---
Redirect 301 /vara-tjanster/ledningssystem-for-arbetsmiljo/ /kunskapsbank/

# --- Arbetsmiljoarbete root → kunskapsbank ---
Redirect 301 /vara-tjanster/arbetsmiljoarbete/ /kunskapsbank/

# --- Vara tjanster root → front page ---
Redirect 301 /vara-tjanster/ /

# --- Catch-all for remaining vara-tjanster sub-pages ---
RewriteRule ^vara-tjanster/vara-arbetsmiljoutbildningar/.+$ /utbildningar/ [R=301,L]
RewriteRule ^vara-tjanster/arbetsmiljoarbete/.+$ /kunskapsbank/ [R=301,L]
RewriteRule ^vara-tjanster/.+$ / [R=301,L]


