# =============================================================================
# kompetensutveckla.se — 301 Redirect Map (OLD → NEW)
# =============================================================================
# Generated: 2026-03-03
# Total explicit redirects: ~120 individual + ~200 city patterns (regex)
# Total estimated coverage: 400+ URLs
#
# ALL redirects are 301 (permanent) to preserve link equity and domain rating.
# Order matters: more specific rules MUST come before general catch-alls.
# =============================================================================

RewriteEngine On
RewriteBase /

# =============================================================================
# SECTION 1: CITY-SPECIFIC PATTERNS (RewriteRule regex)
# Covers ~200 URLs across BAM, BAS P, BAS U, BAS P+U city pages
# Cities: goteborg, stockholm-centrum, malmo, uppsala, vasteras, arvika,
#         borlange, boras, enkoping, eskilstuna, falun, gallivare, gavle,
#         helsingborg, hudiksvall, jonkoping, kalmar, karlskrona, kiruna,
#         linkoping, lulea, norrkoping, pitea, skelleftea, skovde,
#         stockholm-bromma, stockholm-solna, stockholm-alvsjo, sundsvall,
#         sveg, soderhamn, sodertalje, umea, visby, vaxjo, orebro,
#         ornskoldsvik, ostersund, karlstad
# =============================================================================

# --- BAM city pages → /utbildningar/arbetsmiljo/ ---
RewriteRule ^bam-utbildning/bam-utbildning-[a-z0-9-]+/?$ /utbildningar/arbetsmiljo/ [R=301,L]

# --- BAS P+U combined city pages → /utbildningar/bygg/ ---
RewriteRule ^utbildning-bas-p-och-bas-u/bas-p-och-bas-u-utbildning-[a-z0-9-]+/?$ /utbildningar/bygg/ [R=301,L]

# --- BAS P only city pages → /utbildningar/bygg/ ---
RewriteRule ^utbildning-bas-p-och-bas-u/bas-p-utbildning-[a-z0-9-]+/?$ /utbildningar/bygg/ [R=301,L]

# --- BAS U only city pages → /utbildningar/bygg/ ---
RewriteRule ^utbildning-bas-p-och-bas-u/bas-u-utbildning-[a-z0-9-]+/?$ /utbildningar/bygg/ [R=301,L]

# --- Kunskapsbanken articles (100+ topics) → /kunskapsbank/artiklar/ ---
RewriteRule ^vara-tjanster/arbetsmiljoarbete/kunskapsbanken/[a-z0-9-]+/?$ /kunskapsbank/artiklar/ [R=301,L]


# =============================================================================
# SECTION 2: BAM COURSES (explicit)
# =============================================================================

