entElement,{childList:true,subtree:true});setTimeout(function(){mo.disconnect()},5000)}})();</script><!-- /wp:html -->\n\n<!-- wp:html -->\n\n<style>\n.page-insp .arb-insphero{position:relative;width:100%;min-height:520px;display:grid;grid-template-columns:1fr 1fr;overflow:hidden}\n.page-insp .arb-insphero__text{background:#F0EBE1;padding:80px 60px;display:flex;flex-direction:column;justify-content:center}\n.page-insp .arb-insphero__img{background:url('https://arbetsro.searchboost.nu/wp-content/uploads/2026/04/arbetsro-hero-smaland.jpg') 60% center/cover}\n.page-insp .arb-insphero__eyebrow{font-family:Inter,sans-serif;font-size:11px;letter-spacing:5px;text-transform:uppercase;color:#6B8C7A;margin:0 0 22px}\n.page-insp .arb-insphero__h1{font-family:'Playfair Display',serif;font-style:italic;font-weight:400;font-size:clamp(40px,5vw,68px);line-height:1.1;color:#2C3E2D;margin:0 0 28px;letter-spacing:-.01em}\n.page-insp .arb-insphero__lead{font-family:Inter,sans-serif;font-size:17px;line-height:1.85;font-weight:300;color:#2C2925;margin:0;max-width:440px}\n@media (max-width:768px){.page-insp .arb-insphero{grid-template-columns:1fr}.page-insp .arb-insphero__img{min-height:280px}.page-insp .arb-insphero__text{padding:48px 28px}}\n\n.page-insp .arb-articles{padding:120px 32px;background:#FFF}\n.page-insp .arb-articles__inner{max-width:1180px;margin:0 auto}\n.page-insp .arb-articles__head{text-align:center;margin:0 0 64px}\n.page-insp .arb-articles__eyebrow{font-family:Inter,sans-serif;font-size:11px;letter-spacing:4px;text-transform:uppercase;color:#6B8C7A;margin:0 0 18px}\n.page-insp .arb-articles__h2{font-family:'Playfair Display',serif;font-style:italic;font-weight:400;font-size:clamp(32px,4vw,52px);line-height:1.2;color:#2C3E2D;margin:0 0 16px}\n.page-insp .arb-articles__sub{font-family:Inter,sans-serif;font-size:16px;line-height:1.85;color:#2C2925;font-weight:300;margin:0 auto;max-width:520px}\n.page-insp .arb-articles__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:32px}\n@media (max-width:900px){.page-insp .arb-articles__grid{grid-template-columns:repeat(2,1fr)}}\n@media (max-width:600px){.page-insp .arb-articles__grid{grid-template-columns:1fr}}\n.page-insp .arb-art{display:block;text-decoration:none;border:1px solid rgba(44,62,45,.12);border-radius:14px;padding:36px 32px;background:#FCFAF6;transition:all .25s;height:100%}\n.page-insp .arb-art:hover{border-color:rgba(44,62,45,.3);background:#FFF;transform:translateY(-3px)}\n.page-insp .arb-art__cat{font-family:Inter,sans-serif;font-size:10px;letter-spacing:3px;text-transform:uppercase;color:#C4956A;margin:0 0 16px;display:block}\n.page-insp .arb-art__title{font-family:'Playfair Display',serif;font-style:italic;font-weight:400;font-size:23px;line-height:1.25;color:#2C3E2D;margin:0 0 14px}\n.page-insp .arb-art__excerpt{font-family:Inter,sans-serif;font-size:14px;line-height:1.7;color:#444;font-weight:300;margin:0 0 22px}\n.page-insp .arb-art__more{font-family:Inter,sans-serif;font-size:11px;letter-spacing:2.5px;text-transform:uppercase;color:#8B6B4A}\n</style>\n\n<div class=\"page-insp\">\n\n  <section class=\"arb-insphero\">\n    <div class=\"arb-insphero__text\">\n      <p class=\"arb-insphero__eyebrow\">Inspiration & läsning</p>\n      <h1 class=\"arb-insphero__h1\">Tankar om hemmakontoret</h1>\n      <p class=\"arb-insphero__lead\">Praktiska råd, ärliga genomgångar och artiklar om vad som faktiskt skapar arbetsro. Inga sponsrade listor. Ingen klickbete.</p>\n    </div>\n    <div class=\"arb-insphero__img\"></div>\n  </section>\n\n  <div style=\"max-width:900px;margin:0 auto;padding:80px 32px 0\">\n    <h2 style=\"font-family:Playfair Display,serif;font-style:italic;font-weight:400;font-size:32px;color:#2C3E2D;margin:0 0 32px;text-align:center\">De tre grunderna</h2>\n    <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:48px;margin:0 0 64px\">\n      <div>\n        <h3 style=\"font-family:Inter,sans-serif;font-weight:600;font-size:13px;letter-spacing:3px;text-transform:uppercase;color:#8B6B4A;margin:0 0 16px\">01. Ljus</h3>\n        <p style=\"font-family:Inter,sans-serif;font-size:16px;line-height:1.85;color:#444;margin:0;font-weight:300\">Naturligt ljus är alltid bäst. Placera skrivbordet vinkelrätt mot fönstret — inte med ryggen mot eller rakt mot det. Komplettera med en bra bordslampa med justerbar färgtemperatur: varmt på morgonen, kallt mitt på dagen.</p>\n      </div>\n      <div>\n        <h3 style=\"font-family:Inter,sans-serif;font-weight:600;font-size:13px;letter-spacing:3px;text-transform:uppercase;color:#8B6B4A;margin:0 0 16px\">02. Ergonomi</h3>\n        <p style=\"font-family:Inter,sans-serif;font-size:16px;line-height:1.85;color:#444;margin:0;font-weight:300\">Skärmen i ögonhöjd. Armbågarna i 90 grader. Fötterna i golvet. Enkla regler som de flesta ignorerar — och som kostar dem i ryggproblem och huvudvärk. En bra stol är inte en lyx, det är grundläggande utrustning.</p>\n      </div>\n      <div>\n        <h3 style=\"font-family:Inter,sans-serif;font-weight:600;font-size:13px;letter-spacing:3px;text-transform:uppercase;color:#8B6B4A;margin:0 0 16px\">03. Avskalning</h3>\n        <p style=\"font-family:Inter,sans-serif;font-size:16px;line-height:1.85;color:#444;margin:0;font-weight:300\">Mer saker = mer mental brus. Börja med att ta bort hälften av det som ligger på skrivbordet. Förvara det du behöver, inte det du \"kanske behöver\". En ren yta skapar ett renare tänkande.</p>\n      </div>\n      <div>\n        <h3 style=\"font-family:Inter,sans-serif;font-weight:600;font-size:13px;letter-spacing:3px;text-transform:uppercase;color:#8B6B4A;margin:0 0 16px\">04. Atmosfär</h3>\n        <p style=\"font-family:Inter,sans-serif;font-size:16px;line-height:1.85;color:#444;margin:0;font-weight:300\">Gröna växter renar luften och lugnar. En kopp te eller kaffe är ett ritual som signalerar \"nu börjar vi\". Musik eller tystnad — välj medvetet, inte av vana. Dessa detaljer adderar upp till en plats du vill gå till.</p>\n      </div>\n    </div>\n  </div>\n\n  <section class=\"arb-articles\">\n    <div class=\"arb-articles__inner\">\n      <div class=\"arb-articles__head\">\n        <p class=\"arb-articles__eyebrow\">Artiklar & essäer</p>\n        <h2 class=\"arb-articles__h2\">Läs vidare</h2>\n        <p class=\"arb-articles__sub\">Tankar om arbete, koncentration, gränser och hur en plats faktiskt påverkar hur du mår.</p>\n      </div>\n\n      <div class=\"arb-articles__grid\">\n\n        <a href=\"/hemmakontor-tips/\" class=\"arb-art\">\n          <span class=\"arb-art__cat\">Hemmakontor</span>\n          <h3 class=\"arb-art__title\">Den enda saken du behöver göra för att hemmakontoret ska fungera bättre</h3>\n          <p class=\"arb-art__excerpt\">Det finns ingen hemlighet. Det finns ingen trick. Det finns bara en sak som skiljer ett hemmakontor som fungerar från ett som inte gör det.</p>\n          <span class=\"arb-art__more\">Läs artikeln →</span>\n        </a>\n\n        <a href=\"/hemmakontoret-ska-vara-trakigt/\" class=\"arb-art\">\n          <span class=\"arb-art__cat\">Hemmakontor</span>\n          <h3 class=\"arb-art__title\">Varför hemmakontoret ska vara tråkigt</h3>\n          <p class=\"arb-art__excerpt\">Inte tråkigt som i oinspirerat. Tråkigt som i: det ska inte tävla om din uppmärksamhet.</p>\n          <span class=\"arb-art__more\">Läs artikeln →</span>\n        </a>\n\n        <a href=\"/hoj-sankbart-skrivbord-vart/\" class=\"arb-art\">\n          <span class=\"arb-art__cat\">Hemmakontor</span>\n          <h3 class=\"arb-art__title\">Höj- och sänkbart skrivbord: vad är det egentligen värt?</h3>\n          <p class=\"arb-art__excerpt\">Det säljs med löften om förlängd livslängd och ökad produktivitet. Vad stämmer faktiskt? Ärlig genomgång.</p>\n          <span class=\"arb-art__more\">Läs artikeln →</span>\n        </a>\n\n        <a href=\"/stress-distansarbete-forskning/\" class=\"arb-art\">\n          <span class=\"arb-art__cat\">Arbete & välmående</span>\n          <h3 class=\"arb-art__title\">Stress och distansarbete — vad forskning faktiskt säger</h3>\n          <p class=\"arb-art__excerpt\">Studier visar att hemarbete ökar produktiviteten — men också att stressnivåerna kan skjuta i höjden. Hur hänger det ihop?</p>\n          <span class=\"arb-art__more\">Läs artikeln →</span>\n        </a>\n\n        <a href=\"/rutiner-slaar-motivation/\" class=\"arb-art\">\n          <span class=\"arb-art__cat\">Arbete & välmående</span>\n          <h3 class=\"arb-art__title\">Varför rutiner slår motivation — varje gång</h3>\n          <p class=\"arb-art__excerpt\">Motivation är ett tillstånd. Rutiner är ett system. Tillstånd kommer och går. System stannar kvar.</p>\n          <span class=\"arb-art__more\">Läs artikeln →</span>\n        </a>\n\n        <a href=\"/balans-i-arbetslivet-hemma/\" class=\"arb-art\">\n          <span class=\"arb-art__cat\">Arbete & välmående</span>\n          <h3 class=\"arb-art__title\">Balans i arbetslivet — varför det är svårare hemma än på kontoret</h3>\n          <p class=\"arb-art__excerpt\">På kontoret regleras balansen av strukturer du inte valt själv. Hemma måste du skapa dem.</p>\n          <span class=\"arb-art__more\">Läs artikeln →</span>\n        </a>\n\n        <a href=\"/satt-granser-jobba-hemifran/\" class=\"arb-art\">\n          <span class=\"arb-art__cat\">Arbete & välmående</span>\n          <h3 class=\"arb-art__title\">Sätt gränser när jobbet är hemma — utan att känna dig skyldig</h3>\n          <p class=\"arb-art__excerpt\">Gränssättning är inte att vara otillgänglig. Det är att skydda din kapacitet att faktiskt leverera.</p>\n          <span class=\"arb-art__more\">Läs artikeln →</span>\n        </a>\n\n      </div>\n    </div>\n  </section>\n\n</div>\n\n<!-- /wp:html -->",
