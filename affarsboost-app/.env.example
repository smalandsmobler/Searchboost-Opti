# ── Affärsboost App — Miljövariabler ──────────────────────────────────────────
# Kopiera till .env.local och fyll i riktiga värden.
# Lägg ALDRIG .env.local i git (redan i .gitignore).

# ── App-URL (ändra till https://affarsboost.se i produktion) ──────────────────
NEXT_PUBLIC_APP_URL=https://affarsboost.se

# ── Google AI Studio (Gemini 2.0 Flash — Linnéa + Maja) ──────────────────────
# Hämta på: https://aistudio.google.com/app/apikey
GOOGLE_AI_STUDIO_KEY=

# ── Searchboost Opti API (EC2 51.21.116.7) ───────────────────────────────────
# Bas-URL för interna API-anrop (BQ-logging, waitlist, subscriptions)
OPTI_API_BASE=https://51.21.116.7
# API-nyckel för Opti-servern (se SSM: /seo-mcp/dashboard/api-key)
OPTI_API_KEY=sb-api-41bbf2ec7d8a17973d7b7ebcac07aafab9aa777feb08ce78

# ── Cloudflare Turnstile (CAPTCHA-ersättare) ──────────────────────────────────
# Dashboard: https://dash.cloudflare.com → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com
# Använd test-nycklar under utveckling (sk_test_... / pk_test_...)
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook-hemligheterna skapas i Stripe Dashboard → Webhooks → Add endpoint
# Endpoint URL: https://affarsboost.se/api/stripe/webhook
# Events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — skapas i Stripe Dashboard → Products
# Solo-plan: 299 kr/mån (månadsvis recurring)
STRIPE_PRICE_SOLO=price_...
# Tillväxt-plan: 1 000 kr/mån (månadsvis recurring)
STRIPE_PRICE_TILLVAXT=price_...

# ── Session-signering (generera med: openssl rand -base64 32) ─────────────────
# Används för att signera ab_session-cookies efter betalning.
# MÅSTE vara hemlig och minst 32 tecken.
AFFARSBOOST_JWT_SECRET=

# ── Tracking (valfritt — lämna tomma tills IDs är skapade) ───────────────────
# Google Tag Manager
NEXT_PUBLIC_GTM_ID=
# Google Analytics 4
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
# Google Ads
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=
# Meta (Facebook) Pixel
NEXT_PUBLIC_META_PIXEL_ID=
